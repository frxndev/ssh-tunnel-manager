{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSH Tunnel Manager",
  "version": "0.1.0",
  "identifier": "com.fran.sshtunnelmanager",
  "build": {
    "beforeDevCommand": {
      "script": "npm install && npm run dev",
      "cwd": "../frontend"
    },
    "beforeBuildCommand": {
      "script": "npm install && npm run build",
      "cwd": "../frontend"
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSH Tunnel Manager",
        "width": 1200,
        "height": 860,
        "minWidth": 860,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: https://asset.localhost; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "msi",
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Fran Development",
    "copyright": "© 2026 Fran Development",
    "category": "DeveloperTool",
    "shortDescription": "Gestor de túneles SSH con interfaz gráfica",
    "longDescription": "Crea, guarda y controla túneles SSH (local, remoto y SOCKS dinámico) desde una interfaz gráfica, con reconexión automática, keepalive y logs por conexión.",
    "homepage": "https://frxn.pages.dev",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
